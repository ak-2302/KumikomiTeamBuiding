<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface_strong"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="32dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:letterSpacing="0"
        android:text="@string/connection_title"
        android:textColor="@color/ink"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/ipAddressText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:letterSpacing="0"
        android:text="@string/connection_waiting"
        android:textColor="@color/ink_muted"
        android:textSize="15sp" />

    <ImageView
        android:id="@+id/connectionQrCode"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginTop="16dp"
        android:background="@color/white"
        android:contentDescription="@string/qr_code_description"
        android:padding="8dp"
        android:scaleType="fitCenter"
        tools:src="@drawable/ic_launcher_foreground" />

    <TextView
        android:id="@+id/mediaAccessStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:letterSpacing="0"
        android:text="@string/media_access_required"
        android:textColor="@color/ink_muted"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/mediaAccessButton"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginTop="4dp"
        android:letterSpacing="0"
        android:text="@string/open_notification_access" />

</LinearLayout>
