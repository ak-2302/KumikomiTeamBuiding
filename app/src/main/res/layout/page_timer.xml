<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:paddingStart="24dp"
    android:paddingEnd="24dp">

    <TextView
        android:id="@+id/appTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:letterSpacing="0"
        android:text="@string/focus_title"
        android:textColor="@color/ink"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/connectionButton"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:letterSpacing="0"
        android:minWidth="0dp"
        android:text="@string/connection"
        android:textColor="@color/ink_muted"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/appTitle" />

    <FrameLayout
        android:id="@+id/timerFrame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appTitle"
        app:layout_constraintWidth_max="420dp">

        <com.example.kumikomiteambuiding.FocusTimerView
            android:id="@+id/focusTimerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/timer_page_description" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/phaseText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0"
                android:text="@string/focus_phase"
                android:textColor="@color/ink_muted"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/timeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0"
                android:textColor="@color/ink"
                android:textSize="58sp"
                tools:text="25:00" />

            <TextView
                android:id="@+id/timerStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:letterSpacing="0"
                android:text="@string/timer_ready"
                android:textColor="@color/ink_muted"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/timerControls"
        android:layout_width="wrap_content"
        android:layout_height="64dp"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/timerFrame">

        <ImageButton
            android:id="@+id/resetButton"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/timer_reset"
            android:padding="14dp"
            android:src="@drawable/ic_refresh"
            app:tint="@color/ink" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/toggleTimerButton"
            android:layout_width="148dp"
            android:layout_height="56dp"
            android:layout_marginStart="18dp"
            android:letterSpacing="0"
            android:text="@string/timer_start"
            android:textSize="16sp"
            app:cornerRadius="28dp"
            app:icon="@drawable/ic_play"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="@color/white" />
    </LinearLayout>

    <TextView
        android:id="@+id/statsHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        android:letterSpacing="0"
        android:text="@string/stats_page_description"
        android:textColor="@color/ink_muted"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:layout_width="32dp"
        android:layout_height="3dp"
        android:layout_marginBottom="8dp"
        android:background="@color/track"
        app:layout_constraintBottom_toTopOf="@id/statsHint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
